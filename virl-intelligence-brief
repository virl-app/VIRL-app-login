### 4b. Update PlanCard to render format-specific layouts

The PlanCard component should branch based on `card.format`:

```jsx
function PlanCard({card}) {
  // Common metadata row (always shown)
  var metadataRow = (
    <div style={{display:"flex", justifyContent:"space-between", marginBottom: 12}}>
      <div style={metadataStyle}>{card.day} · {card.platform} · {card.format}</div>
      <div style={metadataStyle}>{card.postingTime}</div>
    </div>
  );

  // Format-specific body
  var body;
  switch(card.format) {
    case "video":
      body = <VideoCardBody card={card} />;
      break;
    case "single_image":
      body = <ImageCardBody card={card} />;
      break;
    case "carousel":
      body = <CarouselCardBody card={card} />;
      break;
    case "quote_graphic":
      body = <QuoteCardBody card={card} />;
      break;
    case "story":
      body = <StoryCardBody card={card} />;
      break;
    case "long_form_text":
      body = <LongFormCardBody card={card} />;
      break;
    default:
      body = <DefaultCardBody card={card} />;
  }

  return (
    <div style={cardStyle}>
      {metadataRow}
      {body}
      {/* Common action row at bottom */}
      <ActionRow card={card} />
    </div>
  );
}
```

Each format-specific body component renders the relevant fields with appropriate styling. For example:

```jsx
function CarouselCardBody({card}) {
  return (
    <div>
      <div style={hookStyle}>{card.caption}</div>
      <div style={{marginTop: 14}}>
        <div style={eyebrowStyle}>SLIDES</div>
        {card.slides.map(function(slide){
          return (
            <div key={slide.slideNumber} style={slideStyle}>
              <div style={slideNumberStyle}>{slide.slideNumber}</div>
              <div>
                <div style={slideHeadlineStyle}>{slide.headline}</div>
                <div style={slideBodyStyle}>{slide.body}</div>
                {slide.designDirection && (
                  <div style={designDirectionStyle}>Design: {slide.designDirection}</div>
                )}
              </div>
            </div>
          );
        })}
      </div>
      <div style={hashtagsStyle}>{card.hashtags}</div>
    </div>
  );
}
```

Similarly create `VideoCardBody`, `ImageCardBody`, `QuoteCardBody`, `StoryCardBody`, and `LongFormCardBody`. Each renders the format's specific fields in a clean, scannable layout.

### 4c. Backward compatibility

For existing plans in the database that don't have the `format` field populated, default to `video` (the current implicit behavior). The PlanCard should gracefully handle missing format-specific fields by falling back to the basic hook + caption + hashtags layout.

```javascript
var format = card.format || "video";  // backward compatible default
```

