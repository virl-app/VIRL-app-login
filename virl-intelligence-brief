State management:
```javascript
var [platformFormats, setPlatformFormats] = useState(profile.platformFormats || {});

function toggleFormat(platform, format) {
  setPlatformFormats(function(prev){
    var current = prev[platform] || [];
    var updated;
    if (current.includes(format)) {
      updated = current.filter(function(f){ return f !== format; });
    } else {
      updated = current.concat([format]);
    }
    return Object.assign({}, prev, { [platform]: updated });
  });
}
```

### 2c. Use platform formats in system prompt

```javascript
if (profile.platformFormats && Object.keys(profile.platformFormats).length > 0) {
  prompt += "\n## USER'S PRIMARY POSTING FORMATS\n\n";
  prompt += "The user primarily posts in these formats. Generate content optimized for each:\n\n";

  Object.keys(profile.platformFormats).forEach(function(platform){
    var formats = profile.platformFormats[platform];
    if (formats && formats.length > 0) {
      prompt += "- " + platform + ": " + formats.join(", ") + "\n";
    }
